    create or replace table `novabrew-analytics`.`novabrew_dev_novabrew_marts`.`mart_customer_segments`
      
    
    

    
    OPTIONS()
    as (
      -- models/marts/customers/mart_customer_segments.sql
-- ============================================================
-- NovaBrew Analytics — Mart: Customer Segments (RFM)
-- Post 2: Customer Segmentation
-- ============================================================
-- Builds RFM (Recency, Frequency, Monetary) scores for every
-- customer and assigns a segment label.
--
-- RFM scoring methodology:
--   R (Recency)   — Days since last order. Lower = better.
--   F (Frequency) — Total number of orders. Higher = better.
--   M (Monetary)  — Total revenue. Higher = better.
--
-- Each dimension is scored 1–4 using NTILE quartiles.
-- Combined RFM score drives the segment label.
--
-- Segments:
--   Champions      — R4, high F+M. Best customers.
--   Loyal          — High F, decent R. Regular buyers.
--   Promising      — Recent first purchase, low F.
--   Needs Attention— Mid R+F, declining engagement.
--   At Risk        — Used to be good, hasn't bought recently.
--   Lost           — Low R, low F. Churned.
-- ============================================================

WITH orders AS (

    SELECT * FROM `novabrew-analytics`.`novabrew_dev_novabrew_staging`.`stg_orders`
    WHERE is_revenue_order = TRUE

),

customers AS (

    SELECT * FROM `novabrew-analytics`.`novabrew_dev_novabrew_staging`.`stg_customers`

),

-- ── Step 1: Aggregate order stats per customer ─────────────

customer_orders AS (

    SELECT
        customer_id,
        COUNT(order_id)                              AS order_count,
        SUM(order_total)                             AS total_revenue,
        AVG(order_total)                             AS avg_order_value,
        MIN(order_date)                              AS first_order_date,
        MAX(order_date)                              AS last_order_date,
        DATE_DIFF(
            DATE '2024-06-30',          -- use series end date as "today"
            MAX(order_date),
            DAY
        )                                            AS days_since_last_order,
        COUNTIF(is_first_order)                      AS first_order_count   -- should always = 1

    FROM orders
    GROUP BY customer_id

),

-- ── Step 2: Join to customers (include non-purchasers) ─────

customer_base AS (

    SELECT
        c.customer_id,
        c.acquisition_channel,
        c.channel_type,
        c.state,
        c.age_band,
        c.is_subscriber,
        c.signup_date,

        -- Order stats (NULL for customers who never ordered)
        COALESCE(o.order_count, 0)                   AS order_count,
        COALESCE(o.total_revenue, 0.0)               AS total_revenue,
        COALESCE(o.avg_order_value, 0.0)             AS avg_order_value,
        o.first_order_date,
        o.last_order_date,
        COALESCE(o.days_since_last_order, 999)       AS days_since_last_order,

        -- Has the customer ever purchased?
        (o.customer_id IS NOT NULL)                  AS has_purchased

    FROM customers c
    LEFT JOIN customer_orders o USING (customer_id)

),

-- ── Step 3: Score only purchasing customers ─────────────────
-- We only RFM-score customers who have made at least one purchase.
-- Non-purchasers get segment = 'Non-Buyer'.

purchasers AS (

    SELECT * FROM customer_base WHERE has_purchased = TRUE

),

-- ── Step 4: NTILE quartile scoring (1=worst, 4=best) ───────

rfm_scores AS (

    SELECT
        *,

        -- Recency: lower days_since_last_order = better = higher score
        NTILE(4) OVER (ORDER BY days_since_last_order DESC)  AS r_score,

        -- Frequency: higher order_count = better = higher score
        NTILE(4) OVER (ORDER BY order_count ASC)             AS f_score,

        -- Monetary: higher total_revenue = better = higher score
        NTILE(4) OVER (ORDER BY total_revenue ASC)           AS m_score

    FROM purchasers

),

-- ── Step 5: Derive segment from RFM scores ─────────────────

segmented AS (

    SELECT
        *,
        CONCAT(
            CAST(r_score AS STRING),
            CAST(f_score AS STRING),
            CAST(m_score AS STRING)
        )                                            AS rfm_string,

        r_score + f_score + m_score                  AS rfm_total,

        CASE
            -- Champions: recent, frequent, high spend
            WHEN r_score = 4 AND f_score >= 3 AND m_score >= 3
                THEN 'Champion'

            -- Loyal: frequent buyers, still active
            WHEN f_score >= 3 AND r_score >= 2
                THEN 'Loyal'

            -- Promising: recent but low frequency (new customers)
            WHEN r_score >= 3 AND f_score <= 2 AND order_count <= 2
                THEN 'Promising'

            -- Needs Attention: decent history but slipping
            WHEN r_score = 2 AND f_score >= 2 AND m_score >= 2
                THEN 'Needs Attention'

            -- At Risk: were good customers, gone quiet
            WHEN r_score <= 2 AND f_score >= 3
                THEN 'At Risk'

            -- Lost: low recency, low frequency
            WHEN r_score = 1 AND f_score <= 2
                THEN 'Lost'

            -- Everyone else — mid-tier
            ELSE 'Occasional'

        END                                          AS segment

    FROM rfm_scores

),

-- ── Step 6: Union back non-purchasers ──────────────────────

non_purchasers AS (

    SELECT
        customer_id,
        acquisition_channel,
        channel_type,
        state,
        age_band,
        is_subscriber,
        signup_date,
        order_count,
        total_revenue,
        avg_order_value,
        first_order_date,
        last_order_date,
        days_since_last_order,
        has_purchased,
        NULL AS r_score,
        NULL AS f_score,
        NULL AS m_score,
        NULL AS rfm_string,
        NULL AS rfm_total,
        'Non-Buyer' AS segment

    FROM customer_base
    WHERE has_purchased = FALSE

),

final AS (

    SELECT
        customer_id,
        acquisition_channel,
        channel_type,
        state,
        age_band,
        is_subscriber,
        signup_date,
        order_count,
        ROUND(total_revenue, 2)                      AS total_revenue,
        ROUND(avg_order_value, 2)                    AS avg_order_value,
        first_order_date,
        last_order_date,
        days_since_last_order,
        has_purchased,
        r_score,
        f_score,
        m_score,
        rfm_string,
        rfm_total,
        segment,
        CURRENT_TIMESTAMP()                          AS _updated_at

    FROM segmented

    UNION ALL

    SELECT
        customer_id,
        acquisition_channel,
        channel_type,
        state,
        age_band,
        is_subscriber,
        signup_date,
        order_count,
        ROUND(total_revenue, 2),
        ROUND(avg_order_value, 2),
        first_order_date,
        last_order_date,
        days_since_last_order,
        has_purchased,
        r_score,
        f_score,
        m_score,
        rfm_string,
        rfm_total,
        segment,
        CURRENT_TIMESTAMP()

    FROM non_purchasers

)

SELECT * FROM final
    );
  
